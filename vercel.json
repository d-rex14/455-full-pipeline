{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    {
      "src": "api/predict.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "model.sav" }
    }
  ],
  "routes": [
    { "src": "/api/predict", "dest": "/api/predict.py" },
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
